{
  "name": "fluxer-auditoria-trafego",
  "version": "2.0.0",
  "description": "Sistema de auditoria semanal de tráfego Facebook Ads",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build:server": "tsc",
    "build:client": "cd client && npm install && npm run build",
    "build": "npm run build:server && npm run build:client && node scripts/vercel-workaround-chunk.js",
    "start": "node dist/server.js",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node --import tsx src/server.ts",
    "dev:client": "cd client && npm run dev",
    "dev:all": "npm run dev",
    "create-tables": "ts-node scripts/create-tables-node.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.1",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "get-stream": "^9.0.0",
    "multer": "^2.1.1",
    "papaparse": "^5.4.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.0.0",
    "@types/papaparse": "^5.3.15",
    "@types/pg": "^8.16.0",
    "concurrently": "^9.1.0",
    "pg": "^8.19.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "~5.6.2"
  },
  "overrides": {
    "multer": "^2.1.1"
  }
}
