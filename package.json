{
  "name": "fluxer-auditoria-trafego",
  "version": "2.0.0",
  "description": "Sistema de auditoria semanal de tráfego Facebook Ads",
  "main": "dist/server.js",
  "scripts": {
    "build:server": "tsc",
    "build:client": "cd client && npm install && npm run build",
    "build": "npm run build:server && npm run build:client",
    "start": "node dist/server.js",
    "dev": "ts-node src/server.ts",
    "dev:client": "cd client && npm run dev"
  },
  "dependencies": {
    "express": "^4.18.2",
    "sql.js": "^1.10.3",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "xlsx": "^0.18.5",
    "papaparse": "^5.4.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "typescript": "~5.6.2",
    "ts-node": "^10.9.2",
    "@types/node": "^22.0.0",
    "@types/express": "^5.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/papaparse": "^5.3.15"
  }
}
