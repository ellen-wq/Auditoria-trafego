{
  "version": 2,
  "buildCommand": "npm run build",
  "functions": {
    "api/index.ts": {
      "maxDuration": 30,
      "includeFiles": "public_dist/**,dist/**,src/**"
    }
  },
  "ignore": [
    "server.js",
    "db/database.js",
    "routes/*.js",
    "middleware/*.js",
    "utils/parser.js",
    "engine/rules.js"
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index"
    }
  ]
}
